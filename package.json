{
  "name": "baex-framework",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cd wasm && wasm-pack build --target web --out-dir ../public/wasm && cd .. && rsbuild build",
    "check": "biome check --write",
    "dev": "rsbuild",
    "format": "biome format --write",
    "preview": "rsbuild preview",
    "test": "vitest",
    "docs:gen": "cd docs-api-generator && bun run scanner ../core ../components ../shell ../bridge ../utils ../wasm/src ./ui/src && bun run ui:build",
    "docs:serve": "bun x serve docs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@rsbuild/core": "^2.0.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/cytoscape": "^3.31.0",
    "@types/leaflet": "^1.9.21",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@turf/turf": "^7.3.5",
    "cytoscape": "^3.34.0",
    "goober": "^2.1.19",
    "immer": "^11.1.8",
    "leaflet": "^1.9.4",
    "vis-network": "^10.1.0",
    "zod": "^4.4.3"
  }
}
